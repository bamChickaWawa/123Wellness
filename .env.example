# Copy to .env and fill in. (This file must be named .env, not .env.local.)

# Required — your Postgres connection string (Neon works great, free):
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# Required — base URL of the app in dev:
BASE_URL=http://localhost:3000

# Required — session signing secret. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=replace-me

# Optional — billing is out of scope for this exercise; leave these unset.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=